<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>My requests</title><link rel="stylesheet" href="${pageContext.request.contextPath}/app.css"></head><body><%@ include file="../jspf/header.jspf" %><main><%@ include file="../jspf/flash.jspf" %><h1>My access requests</h1><div class="table-wrap"><table><thead><tr><th>File</th><th>Owner</th><th>Status</th><th>Download</th></tr></thead><tbody><c:forEach items="${requestScope.requests}" var="item"><tr><td><c:out value="${item.filename()}"/></td><td><c:out value="${item.ownerEmail()}"/></td><td><c:out value="${item.status()}"/></td><td><c:if test="${item.status() == 'APPROVED'}"><a class="button" href="${pageContext.request.contextPath}/ViewData?fid=${item.fileId()}">Download</a></c:if></td></tr></c:forEach><c:if test="${empty requestScope.requests}"><tr><td colspan="4">No requests submitted.</td></tr></c:if></tbody></table></div></main></body></html>
