<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>My files</title><link rel="stylesheet" href="${pageContext.request.contextPath}/app.css"></head><body><%@ include file="../jspf/header.jspf" %><main><%@ include file="../jspf/flash.jspf" %><h1>My files</h1><div class="table-wrap"><table><thead><tr><th>Filename</th><th>Description</th><th>Created</th><th>Actions</th></tr></thead><tbody>
<c:forEach items="${requestScope.files}" var="file"><tr><td><c:out value="${file.filename()}"/></td><td><c:out value="${file.description()}"/></td><td><c:out value="${file.createdAt()}"/></td><td><a class="button" href="${pageContext.request.contextPath}/ViewData?fid=${file.id()}">Download</a> <form class="inline" action="${pageContext.request.contextPath}/DeleteFile" method="post"><input type="hidden" name="csrf" value="${sessionScope.csrfToken}"><input type="hidden" name="fid" value="${file.id()}"><button class="danger" type="submit">Delete</button></form></td></tr></c:forEach>
<c:if test="${empty requestScope.files}"><tr><td colspan="4">No files uploaded.</td></tr></c:if></tbody></table></div></main></body></html>
