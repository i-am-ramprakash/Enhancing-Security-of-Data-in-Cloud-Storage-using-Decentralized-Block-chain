<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Integrity audit</title><link rel="stylesheet" href="${pageContext.request.contextPath}/app.css"></head><body><%@ include file="../jspf/header.jspf" %><main><h1>Append-only integrity audit</h1><p>Each entry commits to the previous entry. A failed row marks the chain as tampered.</p><div class="table-wrap"><table><thead><tr><th>ID</th><th>Entity</th><th>Event</th><th>Hash</th><th>Created</th><th>Valid</th></tr></thead><tbody><c:forEach items="${requestScope.entries}" var="entry"><tr><td><c:out value="${entry.id()}"/></td><td><c:out value="${entry.entityType()}"/>/<c:out value="${entry.entityId()}"/></td><td><c:out value="${entry.eventType()}"/></td><td><code><c:out value="${entry.entryHash()}"/></code></td><td><c:out value="${entry.createdAt()}"/></td><td class="${entry.valid() ? 'valid' : 'invalid'}"><c:out value="${entry.valid() ? 'VALID' : 'INVALID'}"/></td></tr></c:forEach><c:if test="${empty requestScope.entries}"><tr><td colspan="6">No audit entries.</td></tr></c:if></tbody></table></div></main></body></html>
