<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Accounts</title><link rel="stylesheet" href="${pageContext.request.contextPath}/app.css"></head><body><%@ include file="../jspf/header.jspf" %><main><h1><c:out value="${requestScope.listedRole}"/> accounts</h1><div class="table-wrap"><table><thead><tr><th>Name</th><th>Email</th><th>Age</th><th>Gender</th></tr></thead><tbody><c:forEach items="${requestScope.accounts}" var="account"><tr><td><c:out value="${account.name()}"/></td><td><c:out value="${account.email()}"/></td><td><c:out value="${account.age()}"/></td><td><c:out value="${account.gender()}"/></td></tr></c:forEach></tbody></table></div></main></body></html>
