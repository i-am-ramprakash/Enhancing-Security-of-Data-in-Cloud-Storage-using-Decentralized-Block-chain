<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Access requests</title><link rel="stylesheet" href="${pageContext.request.contextPath}/app.css"></head><body><%@ include file="../jspf/header.jspf" %><main><%@ include file="../jspf/flash.jspf" %><h1>Access requests</h1><div class="table-wrap"><table><thead><tr><th>File</th><th>Requester</th><th>Status</th><th>Decision</th></tr></thead><tbody>
<c:forEach items="${requestScope.requests}" var="item"><tr><td><c:out value="${item.filename()}"/></td><td><c:out value="${item.requesterEmail()}"/></td><td><c:out value="${item.status()}"/></td><td><form class="inline" action="${pageContext.request.contextPath}/Approve" method="post"><input type="hidden" name="csrf" value="${sessionScope.csrfToken}"><input type="hidden" name="rid" value="${item.id()}"><button name="decision" value="approve">Approve</button><button class="danger" name="decision" value="deny">Deny</button></form></td></tr></c:forEach>
<c:if test="${empty requestScope.requests}"><tr><td colspan="4">No access requests.</td></tr></c:if></tbody></table></div></main></body></html>
